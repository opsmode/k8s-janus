annotations:
  artifacthub.io/changes: |
    - kind: fixed
      description: "UX and reliability improvements"
    - kind: added
      description: "allow renaming central cluster display name from edit clusters panel"
    - kind: fixed
      description: "add patch verb to webui-secrets Role for cluster rename"
    - kind: changed
      description: "remove scheduled rebuild workflow"
    - kind: changed
      description: "weekly scheduled rebuild to pick up Alpine security patches"
    - kind: fixed
      description: "apk upgrade in Dockerfile to pull latest security patches"
    - kind: added
      description: "replace offboard panel with edit clusters — rename display name inline"
    - kind: added
      description: "default cluster names to context name, add separate display name field in setup wizard"
    - kind: changed
      description: "move DockerHub description update to its own workflow"
    - kind: changed
      description: "push DockerHub description on README.md changes to main"
    - kind: changed
      description: "update DockerHub overview from README on every release"
    - kind: changed
      description: "update READMEs for v0.1.33 multi-namespace support"
