annotations:
  artifacthub.io/changes: |
    - kind: changed
      description: "bump chart and image tag to v0.2.0"
    - kind: changed
      description: "reset values.yaml to neutral defaults (ingress disabled, UTC timezone)"
    - kind: added
      description: "avatar, toast, session expiry, logout, hide admin link, rich log colours"
    - kind: added
      description: "add sign out button to header when OIDC is enabled"
    - kind: fixed
      description: "write docker auth directly to config.json to bypass macOS keychain entirely"
    - kind: fixed
      description: "set DOCKER_CONFIG at job level before buildx setup to avoid keychain"
    - kind: fixed
      description: "disable credsStore in docker config to prevent keychain access on self-hosted runner"
    - kind: fixed
      description: "use isolated DOCKER_CONFIG dir to bypass macOS keychain on self-hosted runner"
    - kind: fixed
      description: "use docker login --password-stdin to bypass macOS keychain on self-hosted runner"
    - kind: changed
      description: "remove trigger file"
    - kind: fixed
      description: "use python3/pip3 on self-hosted runner, remove trailing blank line"
    - kind: changed
      description: "verify self-hosted runner is working"
    - kind: changed
      description: "trigger build on self-hosted runner"
    - kind: changed
      description: "switch to self-hosted runner, local buildx cache, macOS-compatible sed"
    - kind: fixed
      description: "rename exception handlers to avoid shadowing builtins"
    - kind: changed
      description: "retrigger build"
    - kind: changed
      description: "retrigger"
    - kind: changed
      description: "trigger build for error pages and admin redirect"
    - kind: added
      description: "styled error pages, admin redirect on login, read-only requester email"
    - kind: added
      description: "add styled 403 page and fix all raw HTML error responses"
    - kind: fixed
      description: "add configmap checksum annotation to trigger pod rollout on config changes"
    - kind: fixed
      description: "use X-Forwarded-Proto for OIDC redirect_uri and disable https_only on session cookie"
    - kind: fixed
      description: "replace @app.middleware auth guard with BaseHTTPMiddleware for correct session ordering"
    - kind: fixed
      description: "move SessionMiddleware after @app.middleware decorators to ensure correct stack order"
    - kind: fixed
      description: "remove duplicate runs-on in lint job"
    - kind: added
      description: "add ExternalSecret support for OIDC credentials"
    - kind: changed
      description: "install deps from per-component requirements, drop root requirements.txt"
    - kind: fixed
      description: "build job checks out latest main to include bot-updated requirements.txt"
    - kind: changed
      description: "update requirements.txt"
