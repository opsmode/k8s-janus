annotations:
  artifacthub.io/changes: |
    - kind: removed
      description: "command history from status page and API endpoint"
    - kind: fixed
      description: "remove duplicate skip block and unused var in _setup_remote_clusterroles"
    - kind: fixed
      description: "skip central cluster in _setup_remote_clusterroles"
    - kind: fixed
      description: "strip ANSI escape sequences from command history capture"
    - kind: changed
      description: "demote shell probe-failed log to DEBUG"
    - kind: fixed
      description: "reject duplicate NS requests from same requester"
    - kind: fixed
      description: "unique token secret names per namespace + remove NS tab truncation"
    - kind: fixed
      description: "correct argocd repo org in ci (opsmode not devcops-xyz)"
    - kind: changed
      description: "bold amber cluster name chips in request tables and status page"
    - kind: fixed
      description: "add update+patch to controller ClusterRole secrets verbs"
    - kind: fixed
      description: "multi-namespace terminal and status page"
    - kind: changed
      description: "auto-update ArgoCD image tag after successful build"
    - kind: added
      description: "single CRD multi-namespace access + ns selector UI"
    - kind: changed
      description: "remove wait-for-kubeconfigs init container"
    - kind: added
      description: "multi-namespace access grants + controller init container for setup gating"
    - kind: changed
      description: "single cluster + multi-NS selection in request form"
    - kind: added
      description: "multi-cluster and multi-namespace selection in request form"
