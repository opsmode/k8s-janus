annotations:
  artifacthub.io/changes: |
    - kind: changed
      description: "bump chart to v0.1.31, update READMEs for setup wizard"
    - kind: fixed
      description: "skip context selection prompt in browser mode (always use all)"
    - kind: fixed
      description: "better upload error reporting + always print URL in browser mode"
    - kind: added
      description: "restructure setup-upload.sh — ask CLI vs Browser at start"
    - kind: fixed
      description: "remove port-forward command block from admin page"
    - kind: fixed
      description: "add list verb to webui deployments RBAC rule"
    - kind: changed
      description: "drop CLI mode, always redirect to browser after upload"
    - kind: changed
      description: "revert TUI pickers to simple numbered prompts"
    - kind: fixed
      description: "remove .sh suffix from mktemp template (macOS mktemp requirement)"
    - kind: fixed
      description: "re-exec by re-downloading script when stdin is not a tty"
    - kind: fixed
      description: "read escape sequences byte by byte to fix arrow keys in curl|bash"
    - kind: fixed
      description: "read arrow keys safely in curl|bash via single read with timeout"
    - kind: added
      description: "arrow-key TUI selectors throughout setup-upload.sh"
    - kind: fixed
      description: "use /dev/tty for prompts so curl|bash works, clarify central cluster"
    - kind: fixed
      description: "ask which context is management before port-forward"
    - kind: added
      description: "ask user to select contexts before uploading kubeconfig"
    - kind: added
      description: "add close split button to pane A (both panes now closeable)"
    - kind: fixed
      description: "align setup wizard header with other pages (gradient logo box + GitHub link)"
    - kind: fixed
      description: "revoke all cluster access on offboard before removing kubeconfig secret"
    - kind: fixed
      description: "add approved.gif and alert to Approved phase on status page"
    - kind: added
      description: "setup wizard offboarding + redirect URL auto-detect + port-forward cmd"
    - kind: fixed
      description: "add 'update' verb to webui-secrets Role for kubeconfig secret upsert"
    - kind: fixed
      description: "RBAC list secrets + forward-ref + restart button in setup wizard"
    - kind: fixed
      description: "rename ambiguous variable 'l' to 'line' in remove-cluster handler (E741)"
    - kind: changed
      description: "remove CLUSTERS env entirely — central identity via JANUS_CLUSTER_NAME"
    - kind: added
      description: "auto-discover clusters, wizard force-recreate RBAC, pod restart, cluster removal"
    - kind: fixed
      description: "replace dropdown with free-text cluster name input; remove configured_remotes dependency"
    - kind: fixed
      description: "show cluster name dropdown only on checkbox check; remove wrong auto-assign"
    - kind: changed
      description: "remove init container wait-for-kubeconfigs"
    - kind: fixed
      description: "map kubeconfig contexts to configured cluster names; fix secret naming"
    - kind: fixed
      description: "redesign cluster section headers; fix V1TokenRequestSpec for token issuance"
    - kind: fixed
      description: "remove auto-redirect, show Go to Dashboard button when setup completes"
    - kind: fixed
      description: "clearer section headers in cluster select; don't redirect on errors; pyyaml venv fallback"
    - kind: fixed
      description: "pass session_id to browser URL so wizard skips upload panel after script upload"
    - kind: fixed
      description: "auto-install pyyaml if missing in system python"
    - kind: fixed
      description: "use raw GitHub URL for upload-helper so it works before port-forward is running"
    - kind: fixed
      description: "add heartbeat output so piped script doesn't hang silently"
    - kind: changed
      description: "cache pip deps to speed up lint job"
    - kind: fixed
      description: "pipe upload-helper directly to bash to avoid filename conflict"
    - kind: added
      description: "setup-upload.sh auto starts/stops port-forward, waits for Ctrl+C to clean up"
    - kind: fixed
      description: "make curl upload-helper command copyable via cmd-block in drop zone"
    - kind: fixed
      description: "use curl -so to save upload-helper with correct filename"
    - kind: added
      description: "serve setup-upload.sh from webui at /setup/upload-helper, move script into image"
    - kind: added
      description: "add setup-upload.sh to auto-resolve exec-based auth and upload kubeconfig to wizard"
    - kind: fixed
      description: "remove accept filter from file input so extensionless kubeconfig files can be selected"
    - kind: fixed
      description: "add macOS hidden folder hint (Shift+Cmd+.) to kubeconfig drop zone"
    - kind: fixed
      description: "repair copy buttons in setup wizard (fallback for non-secure context, strip comment spans)"
    - kind: fixed
      description: "remove stale _setup_complete_cache references after redirect removal"
    - kind: changed
      description: "make setup wizard always accessible from admin page, drop redirect middleware"
    - kind: added
      description: "add web-based setup wizard for remote cluster onboarding"
    - kind: changed
      description: "update artifacthub.io/changes for v0.1.30"
