annotations:
  artifacthub.io/changes: |
    - kind: changed
      description: "bump to v1.0.5 — PS1/bash fix, quick cmds TDZ fix, status page improvements"
    - kind: fixed
      description: "use bash --norc --noprofile to prevent rc files overwriting colored PS1"
    - kind: fixed
      description: "move _cmdsEnabled before setActivePane to fix TDZ ReferenceError; improve status page layout and approved-by visibility"
    - kind: fixed
      description: "inject colored PS1 via shell -c + exec at open time, not stdin injection"
    - kind: fixed
      description: "colored PS1 — use temp vars for escape bytes, tested locally"
    - kind: fixed
      description: "use printf to inject PS1 escape bytes — works in bash/sh/ash"
