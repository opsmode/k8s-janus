annotations:
  artifacthub.io/changes: |
    - kind: added
      description: "add native OIDC/OAuth2 SSO support"
    - kind: added
      description: "colorize log line tokens (timestamp, level, logger, message)"
    - kind: fixed
      description: "set uvicorn.access to WARNING level to silence scanner noise"
    - kind: added
      description: "make oauth2-proxy optional for ingress"
    - kind: added
      description: "enable nginx ingress for janus.infroware.com"
    - kind: fixed
      description: "drop log lines on QueueFull instead of crashing, increase SSE queue to 1000"
    - kind: fixed
      description: "replace kopf field watcher with periodic TTL reconcile loop to eliminate progress patch conflicts"
    - kind: fixed
      description: "use kopf when= filter to skip on_expires_at_changed on initial grant"
    - kind: added
      description: "drag-to-resize panes in logs and terminal views"
    - kind: fixed
      description: "skip on_expires_at_changed on initial grant (old=None) to avoid kopf patch conflict"
    - kind: changed
      description: "suppress page request noise from access log"
    - kind: fixed
      description: "run log stream iterator in executor thread to avoid blocking event loop"
    - kind: fixed
      description: "ci sed pattern matches any image tag (semver, sha, etc)"
    - kind: added
      description: "add /logs page and TTL extension for active access requests"
    - kind: changed
      description: "add GitHub release badge back to AH readme"
    - kind: changed
      description: "trim AH readme to description only, refer to GH for setup refactor: reduce webui log noise — demote polling to DEBUG, filter uvicorn access log fix: redirect-url detects ingress hostname before LB IP fix: browser mode opens select panel instead of auto-running setup"
    - kind: fixed
      description: "redirect-url detects ingress hostname before LB IP"
    - kind: fixed
      description: "browser mode opens select panel instead of auto-running setup"
